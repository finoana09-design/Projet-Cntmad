{% extends 'base.html.twig' %}

{% block body %}


	<table class="table table-hover ">
		<thead>
			<tr>
				<th class="bg-secondary " scope="col"></th>
				<th class="bg-secondary text-white" scope="col">FILIERE</th>
				<th class="bg-secondary text-white" scope="col">NIVEAU</th>
				<th class="bg-secondary text-white" scope="col">MATIERE</th>


			</tr>
		</thead>
		{% for matiere in matieres %}
			<tbody>
				<tr class="table-secondary">
					<th scope="row"></th>
					<td>{{matiere.niveau.filiere.filiere}}</td>
					<td>{{matiere.niveau.niveau}}</td>
					<td>{{matiere.nameMatiere}}</td>


				</tr>
			</tbody>
		{% endfor %}
	</table>
	<div class="form-group">
		<label class="">To add a new matter...</label>
		<a class="btn btn-success" href="{{ path('add_matiere') }}" role="button">clic here</a>
	</div>
{% endblock %}
