{% extends 'base.html.twig' %}

{% block body %}

	<div class="text-center  align-items-center justify-content-center text-dark ">


		<div class="card mb-3">
			<h5 class="card-header">Student Mark details</h5>


			<div class="card-body">
				<h3 class="card-title">{{ student.firstname }}</h3>
				<h5 class="card-title">{{ student.name }}</h5>

			</div>


			<ul class="list-group list-group-flush">
				<li class="list-group-item">{{ student.niveau.filiere.Filiere }}</li>
				<li class="list-group-item">{{ student.niveau.niveau }}</li>

				<li class="list-group-item">
					<table class="table table-hover">
						<thead>
							<tr>
								<th scope="col">Matiere</th>
								<th scope="col">Examen Partielle</th>
								<th scope="col">Examen Final</th>

								<th scope="col">Total (/ 40)</th>
								<th scope="col">Moyenne Matiere(/ 20)</th>

							</tr>
						</thead>
						<tbody>

							{% for note in notes %}
								<tr class="table-secondary">
									<th scope="row">{{note.matieres.nameMatiere}}</th>

									<td>{{ note.Partielle }}</td>
									<td>{{ note.Final }}</td>

									<td>{{ note.Partielle + note.Final}}</td>

									<td>{{ (note.Partielle + note.Final)/2 }}</td>
								</tr>
							{% endfor %}

						</tbody>
						<thead>
							<tr>

								<th scope="col"></th>
								<th scope="col"></th>
								<th scope="col"></th>
								<th scope="col">Total des Notes</th>
								<th scope="col">Moyenne General</th>
							</tr>
						</thead>
						<tr class="table-secondary">
							<th scope="row"></th>


							<td></td>
							<td></td>
							<td>{{ total }}
								/ 400</td>
							<td>{{moyen}}
								/ 20</td>
						</tr>
						<tr class="table-secondary">
							<th scope="row"></th>


							<td colspan="5">
								{% if moyen > 10 %}
									Felicitation , Vous êtes admis en niveau superieur.
								{% else %}
									Malheureusement, Vous n'êtes pas admis en niveau superieur.
								{% endif %}
							</td>
						</tr>
					</table>
				</li>
			</ul>
			<div class="card-body">
				<a class="btn btn-danger btn-lg" href="#" role="button">print</a>
				<a class="btn btn-danger btn-lg" href="#" role="button">send by email</a>
			</div>
			<div class="card-footer text-muted">Copyrigth Finoana ANDRIANJAKA 2021</div>
		</div>
	{% endblock %}
